---
import { cn } from "@/lib/utils";
import { buttonVariants } from "./ui/button";

const LinkClass = cn(buttonVariants({ variant: "link" }), "p-0");
---

<footer
	class="flex flex-col items-center gap-x-2 pb-10 pt-16 font-medium md:flex-row md:justify-between">
	<p>
		Powered by <a href="https://astro.build/" class={LinkClass}>Astro</a> and Hosted by <a
			href="https://vercel.com/"
			class={LinkClass}>Vercel</a
		>
	</p>
	<p>&copy; 2023 Ahmad Nur Sahid</p>
</footer>
